# .env.example
# Copiar a .env y llenar con tus valores

# ============================================================================
# BASE DE DATOS
# ============================================================================

# PostgreSQL connection string
# Formato: postgresql://usuario:contraseña@host:puerto/basedatos
DATABASE_URL="postgresql://orion:password@localhost:5432/orion"

# ============================================================================
# SERVIDOR EXPRESS
# ============================================================================

# Puerto donde corre Express
PORT=3000

# Entorno: development, test, production
NODE_ENV="development"

# CORS: origen permitido
CORS_ORIGIN="http://localhost:3000"

# Nivel de logs: debug, info, warn, error
LOG_LEVEL="debug"

# ============================================================================
# LLM LOCAL (Ollama)
# ============================================================================

# URL de Ollama (debe estar corriendo en otra terminal)
# Terminal: ollama serve
OLLAMA_URL="http://localhost:11434"

# Modelo LLM a usar
# Modelo principal: Qwen 3.5 9B
OLLAMA_MODEL="qwen2.5:3b"

# Timeout para llamadas a Ollama (milisegundos)
OLLAMA_TIMEOUT=30000

# ============================================================================
# LLM CLOUD (Opcional - Fallback)
# ============================================================================

# Claude API key (si quieres fallback a cloud)
# Obtener en: https://console.anthropic.com
# CLAUDE_API_KEY="sk-ant-..."

# OpenAI API key (futuro)
# OPENAI_API_KEY="sk-..."

# ============================================================================
# 🎤 SPEECH SERVICES (STT - Speech To Text)
# ============================================================================

# Whisper model size
# tiny=39M, base=140M, small=466M, medium=1.5GB, large=2.9GB
# MVP 1: base (buen balance)
# MVP 3+: small o medium para mejor precisión
WHISPER_MODEL="small"

# ============================================================================
# 🔊 TEXT TO SPEECH (TTS) — cliente Python con Kokoro
# ============================================================================

# Voz de Kokoro en español para el cliente Python
# ef_dora = mujer español (recomendada) ⭐
# em_alex = hombre español
KOKORO_PY_VOICE="ef_dora"

# Velocidad de síntesis (0.5 - 2.0)
# 1.0 = velocidad normal
KOKORO_SPEED="1.0"

# ============================================================================
# AUDIO — cliente Python (client/orion_client.py)
# ============================================================================

# Sample rate del micrófono (Hz)
# Estándar: 16000 (16kHz)
AUDIO_SAMPLE_RATE=16000

# ============================================================================
# WAKE WORD / VAD — cliente Python (client/orion_client.py)
# ============================================================================

# Modo de agresividad del WebRTC VAD (0 = permisivo, 3 = agresivo)
# 3 filtra bien el ruido de fondo; bajar a 2 si corta frases
VAD_MODE=3

# Segundos de silencio para cortar la grabación del comando
SILENCE_DURATION=1.5

# Duración máxima del comando en segundos
MAX_RECORD_SECS=10.0

# ============================================================================
# COMANDOS Y SEGURIDAD (MVP 1)
# ============================================================================

# Habilitar validación estricta de comandos
ENABLE_COMMAND_VALIDATION=true

# Lista de comandos permitidos (separados por coma)
# Si está vacío, todos los comandos del whitelist están permitidos
ALLOWED_COMMANDS="open_app,play_music,stop_music,get_time,get_weather,search"

# Bloquear comandos peligrosos (rm -rf, etc)
BLOCK_DANGEROUS_COMMANDS=true

# ============================================================================
# AUTENTICACIÓN Y PERMISOS (MVP 3+)
# ============================================================================

# JWT secret para tokens
# Generar: openssl rand -base64 32
# JWT_SECRET="tu-secret-muy-largo-aqui"

# JWT expiration time
# JWT_EXPIRATION="24h"

# Hash rounds para bcrypt
# BCRYPT_ROUNDS=10

# ============================================================================
# SPEAKER IDENTIFICATION (MVP 3+)
# ============================================================================

# Azure Speaker Recognition (opcional)
# SPEAKER_API_KEY="tu-api-key"
# SPEAKER_REGION="eastus"

# Umbral de similitud de voz (0-1)
# Más alto = más estricto
# SPEAKER_SIMILARITY_THRESHOLD="0.85"

# ============================================================================
# HOME ASSISTANT (MVP 5+)
# ============================================================================

# URL de Home Assistant
# HA_URL="http://localhost:8123"

# Token de acceso de Home Assistant
# HA_TOKEN="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# ============================================================================
# DESARROLLO Y TESTING
# ============================================================================

# Modo debug (más logs)
DEBUG=true

# Modo test (usar servicios mock)
TEST_MODE=false

# Seed inicial de datos en BD
SEED_INITIAL_DATA=false

# ============================================================================
# NOTAS IMPORTANTES
# ============================================================================

# 1. NUNCA subir .env a GitHub (usar .env.example)
#
# 2. Valores por defecto:
#    - DATABASE_URL: necesario
#    - OLLAMA_URL: necesario
#    - KOKORO_VOICE, KOKORO_DTYPE, KOKORO_DEVICE: opcionales (con defaults)
#    - Resto: opcionales con defaults
#
# 3. Para desarrollo local:
#    - Copiar este archivo a .env
#    - Cambiar valores según tu setup
#    - Asegúrate que Ollama corre en otra terminal
#    - Kokoro-JS se descarga automáticamente (primera vez ~100MB)
#
# 4. Para producción:
#    - Usar variables de entorno del sistema
#    - No crear archivo .env (usar CI/CD)
#    - Cambiar NODE_ENV="production"
#    - Usar certificados SSL (HTTPS)
#    - Usar voz masculina o neutra (menos personal)
#
# 5. Para testing:
#    - TEST_MODE=true
#    - DATABASE_URL="postgresql://..."
#    - NODE_ENV="test"
#
# 6. Stack de voz (Orion):
#    - Wake word: Vosk (vocabulario completo español)
#    - VAD: WebRTC VAD (detecta voz real, no amplitud)
#    - STT (Speech to Text): faster-whisper (Python, local)
#    - TTS (Text to Speech): Kokoro Python — ef_dora/em_alex
#    - LLM: Ollama (local)